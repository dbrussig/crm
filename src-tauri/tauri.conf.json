{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mietpark CRM Desktop",
  "version": "0.3.18",
  "identifier": "com.serverraum247.mietparkcrm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mietpark CRM Desktop",
        "width": 1440,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "macOS": {
      "signingIdentity": null,
      "entitlements": "Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://gitlab.com/api/v4/projects/Serverraum247%2Fmietpark-crm-desktop/packages/generic/mietpark-crm-desktop/latest/latest.json"
      ],
      "dialog": false,
      "pubkey": "CHANGE_ME_TAURI_UPDATER_PUBLIC_KEY"
    }
  }
}
