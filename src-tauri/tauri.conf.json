{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mietpark CRM Desktop",
  "version": "0.1.0",
  "identifier": "com.serverraum247.mietparkcrm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mietpark CRM Desktop",
        "width": 1440,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "macOS": {
      "signingIdentity": null
    }
  }
}
